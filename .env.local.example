# Site URL
NEXT_PUBLIC_SITE_URL=https://turnera.com

# Resend Configuration
# Obtén tu API key desde: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# REQUERIDO: ID de la audiencia en Resend (debe ser un UUID válido)
# Obtén el UUID desde: https://resend.com/audiences
# El UUID tiene formato: 78261eea-8f8b-4381-83c6-79fa7120f1cf
RESEND_AUDIENCE_ID=78261eea-8f8b-4381-83c6-79fa7120f1cf
